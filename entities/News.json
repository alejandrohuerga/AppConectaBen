{
  "name": "News",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Local",
        "Noticia",
        "Deporte",
        "Cultura",
        "Emprendimiento",
        "Otros"
      ]
    },
    "image_url": {
      "type": "string"
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "likes": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "category"
  ]
}